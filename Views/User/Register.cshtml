@model User

<div class="container mt-5">
    <div class="card shadow p-4 my-5">

        <h2 class="text-center mb-4 text-danger">Blood Donor Registration</h2>

        <!-- Success Message -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        <!-- Duplicate Message -->
        @if (ViewBag.DuplicateMessage != null)
        {
            <div class="alert alert-danger">
                @ViewBag.DuplicateMessage
                <br />
                <a href="/User/Login">Go to Login</a>
            </div>
        }

        <!-- Validation Summary -->
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <form method="post">

            <div class="row">

                <!-- Name -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Name *</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <!-- Email -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Email *</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- Phone -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Phone Number *</label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <!-- Alternate Phone -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Alternate Phone</label>
                    <input asp-for="AlternatePhone" class="form-control" />
                </div>

                <!-- Gender -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Gender *</label><br />
                    <input type="radio" asp-for="Gender" value="Male" /> Male
                    <input type="radio" asp-for="Gender" value="Female" class="ms-2" /> Female
                    <input type="radio" asp-for="Gender" value="Neutral" class="ms-2" /> Neutral
                    <input type="radio" asp-for="Gender" value="Prefer not to say" class="ms-2" /> Prefer not to say
                    <br />
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>

                <!-- Blood Group -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Blood Group *</label>
                    <select asp-for="BloodGroup" class="form-control">
                        <option value="">Select</option>

                        <optgroup label="Common">
                            <option>A+</option>
                            <option>A-</option>
                            <option>B+</option>
                            <option>B-</option>
                            <option>O+</option>
                            <option>O-</option>
                            <option>AB+</option>
                            <option>AB-</option>
                        </optgroup>

                        <optgroup label="Rare">
                            <option>Bombay (hh)</option>
                        </optgroup>
                    </select>
                    <span asp-validation-for="BloodGroup" class="text-danger"></span>
                </div>

                <!-- Location -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Location *</label>
                    <input asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <!-- Pin Code -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Pin Code *</label>
                    <input asp-for="PinCode" class="form-control" />
                    <span asp-validation-for="PinCode" class="text-danger"></span>
                </div>

                <!-- Tattoos -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Tattoos</label><br />
                    <input type="radio" asp-for="HasTattoos" value="true" /> Yes
                    <input type="radio" asp-for="HasTattoos" value="false" class="ms-2" /> No
                </div>

                <!-- Disability -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Disability</label><br />
                    <input type="radio" asp-for="HasDisability" value="true" /> Yes
                    <input type="radio" asp-for="HasDisability" value="false" class="ms-2" /> No
                </div>

                <!-- Last Donation Date -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Last Donation Date</label>
                    <input asp-for="LastDonationDate" type="date" class="form-control" />
                    <small class="text-muted">Leave empty if never donated</small>
                    <span asp-validation-for="LastDonationDate" class="text-danger"></span>
                </div>

            </div>

            <!-- Submit Button -->
            <div class="text-center mt-3">
                <button type="submit" class="btn btn-primary px-5">Register</button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}