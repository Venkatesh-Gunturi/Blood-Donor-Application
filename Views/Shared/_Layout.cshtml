<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BloodDonorApplication</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BloodDonorApplication.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
       <nav style="background-color:#333; padding:10px;">
    <a href="/" style="color:white; margin-right:15px;">Home</a>
    <a href="/User/Register" style="color:white; margin-right:15px;">Register</a>
    <a href="/User/List" style="color:white;">Donor List</a>
</nav>
    </header>
    <div class="container">
        <main class="flex-grow-1">
             @RenderBody()
        </main>
    </div>

   <footer class="bg-light text-center py-3 mt-auto">
    <p>© 2026 - BloodDonorApplication - Privacy</p>
   </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
